{
  "name": "xpp-web-port",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based XPPAUT port using WASM",
  "license": "GPL-2.0-or-later",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev -w apps/web",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --check .",
    "wasm:build": "npm run build:wasm -w packages/wasm-core"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
